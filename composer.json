{
    "name": "muradbdinfo/laravelai",
    "description": "Unified AI chat for Laravel — Ollama, OpenAI, Anthropic (Claude), DeepSeek. One interface, any AI.",
    "keywords": ["laravel", "ai", "ollama", "openai", "chatgpt", "claude", "anthropic", "deepseek", "llm"],
    "license": "MIT",
    "authors": [
        {
            "name": "Md Murad Hosen",
            "email": "muradbd.info@gmail.com",
            "homepage": "https://www.easyit.com.bd"
        }
    ],
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/muradbdinfo"
        },
        {
            "type": "custom",
            "url": "https://buymeacoffee.com/muradbdinfo"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "autoload": {
        "psr-4": {
            "EasyAI\\LaravelAI\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "EasyAI\\LaravelAI\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "EasyAI\\LaravelAI\\AIServiceProvider"
            ],
            "aliases": {
                "AI": "EasyAI\\LaravelAI\\Facades\\AI"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}